model Plan {
  id       String               @id @default(cuid())

  planId   EnumSubscriptionType @unique @map("plan_id")
  description String

  price             Float
  period            BillingPeriod
  storeLimit        Int?           @map("store_limit")
  productLimit      Int?           @map("product_limit")
  isPopular Boolean @default(false) @map("is_popular")

  stripeProductId String               @map("stripe_product_id")
  stripePriceId String?              @map("stripe_price_id")

  features String[]

  subscriptions     Subscription[]
  nextSubscriptions Subscription[] @relation("NextPlan")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plan")
}

model Subscription {
  id        String   @id @default(cuid())

  stripeSubscriptionId String? @map("stripe_subscription_id")

  status EnumSubscriptionStatus @default(PENDING)
  startDate DateTime @default(now()) @map("start_date")
  endDate   DateTime? @map("end_date")
  nextBillingDate DateTime?              @map("next_billing_date")
  trialEndAt      DateTime?              @map("trial_end_at")
  period       BillingPeriod
  storeLimit   Int?         @map("store_limit")
  productLimit Int?         @map("product_limit")
  customerId   String?      @map("customer_id")

  order     Order?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  plan   Plan                 @relation(fields: [planId], references: [planId])
  planId EnumSubscriptionType @map("plan_id")

  nextPlan   Plan?                 @relation("NextPlan", fields: [nextPlanId], references: [planId])
  nextPlanId EnumSubscriptionType? @map("next_plan_id")

  cancelledAt     DateTime? @map("cancelled_at")
  cancelledReason Json?     @map("cancelled_reason")
  pausedAt        DateTime? @map("paused_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription")
}

model Order {
  id        String   @id @default(cuid())

  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  stripeSessionId String? @map("stripe_session_id")
  stripeChargeId String? @map("stripe_charge_id")
  totalPrice      Float

  provider    PaymentProvider
  status      EnumOrderStatus @default(PENDING)

  externalId  String? @map("external_id")
  providerMeta Json?  @map("provider_meta")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  subscriptionId  String? @unique @map("subscription_id")
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payoutCompletedAt DateTime @default(now()) @map("payout_completed_at")

  @@map("order")
}

model OrderItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quantity Int
  price    Float

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String? @map("order_id")

  product   Product? @relation(fields: [productId], references: [id])
  productId String?  @map("product_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  cachedProductTitle String?
  cachedProductImages String[]
  status      EnumOrderItemStatus @default(PENDING)

  stripeTransferId String? @map("stripe_payout_transfer_id")
  payoutCompletedAt DateTime @default(now()) @map("payout_completed_at")

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  @@map("order_item")
}

model BillingInfo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique @map("user_id")

  serviceId String @map("service_id")

  stripeCustomerId           String? @map("stripe_customer_id")
  stripeDefaultPaymentMethod String? @map("stripe_default_payment_method")

  stripeTestClockId String? @map("stripe_test_clock_id")
  @@map("billing_info")
}

enum EnumProductState {
  NEW
  USED
}

enum BillingPeriod {
  MONTHLY
  YEARLY

  @@map("billing_period")
}

enum EnumSubscriptionType {
  FREE
  ADVANCED
  ADVANCED_ANNUAL
  PREMIUM
  PREMIUM_ANNUAL
}

enum EnumSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  PENDING_DOWNGRADE
  UPGRADING
  OVERDUE
  PAUSED
  TRIALING

  @@map("subscription_status")
}

enum PaymentProvider {
  STRIPE
  YOOKASSA

  @@map("payment_provider")
}

enum EnumOrderStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
  PAUSED
  PAYED_TO_SELLER

  @@map("order_status")
}

enum EnumOrderItemStatus {
  PENDING
  FAILED
  REFUNDED
  TRANSFER_CREATED
  TRANSFER_PAYED

  @@map("order_item_status")
}

enum CurrencyEnum {
  USD
  EUR
  RUB
  @@map("currency_enum")
}

enum EnumRole {
  USER
  ADMIN
  SUPER_ADMIN
}