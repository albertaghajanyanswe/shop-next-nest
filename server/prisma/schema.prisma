generator client {
  provider = "prisma-client-js"
  runtime             = "nodejs"

}

datasource db {
  provider = "postgresql"
  url      = env("DB_URI")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  email    String  @unique
  password String?

  name    String  @default("Not Provided")
  picture String?
  country    String?
  city       String?
  address    String?
  phone      String?

  username String? @unique

  stores Store[]

  favorites     Product[] @relation("UserFavorites")
  reviews       Review[]
  orders        Order[]
  orderItems    OrderItem[]
  products      Product[] @relation("UserProducts")
  brand         Brand[]
  category      Category[]
  billingInfo   BillingInfo?
  subscription  Subscription[]

  stripeAccountId String? @map("stripe_account_id")

  role  EnumRole   @default(USER)
  @@map("user")
}

model Store {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  title       String
  description String?
  images      String[]
  country    String?
  city       String?
  address    String?
  phone      String?

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @map("user_id")

  products   Product[]
  categories Category[]
  colors     Color[]
  reviews    Review[]
  orderItems OrderItem[]
  brands     Brand[]


  isDefaultStore Boolean @default(false)
  isPublished    Boolean @default(true)
  isBlocked      Boolean @default(false)

  @@map("store")
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  title       String
  description String?
  price       Float
  oldPrice    Float?
  images      String[]

  state EnumProductState @default(NEW)

  reviews    Review[]
  orderItems OrderItem[]

  totalViews Int @default(0)
  totalLikes Int @default(0)

  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId String? @map("store_id")

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?   @map("category_id")

  color   Color? @relation(fields: [colorId], references: [id], onDelete: SetNull)
  colorId String? @map("color_id")

  createdBy User?   @relation("UserProducts", fields: [userId], references: [id], onDelete: Cascade)
  userId    String? @map("user_id")

  favoritedBy User[] @relation("UserFavorites")

  brand   Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  brandId String? @map("brand_id")

  isPublished Boolean @default(true)
  isBlocked   Boolean @default(false)

  @@map("product")
}

model Category {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name        String @unique
  description String?
  images      String[]
  rating      Float?
  products Product[]

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  user   User?  @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  @@map("category")
}

model Brand {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name String @unique
  description String?
  images      String[]
  rating      Float?

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  user   User?  @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  products Product[]

  @@map("brand")
}

model Color {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name  String @unique
  value String

  products Product[]

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  @@map("color")
}

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  text   String
  rating Int

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @map("user_id")

  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String?  @map("product_id")

  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId String? @map("store_id")

  @@map("review")
}

