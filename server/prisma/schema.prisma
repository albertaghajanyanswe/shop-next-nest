generator client {
  provider = "prisma-client-js"
  runtime             = "nodejs"

}

datasource db {
  provider = "postgresql"
  url      = env("DB_URI")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  email    String  @unique
  password String?

  name    String  @default("Not Provided")
  picture String?
  country    String?
  city       String?
  address    String?
  phone      String?

  username String? @unique

  stores Store[]

  favorites     Product[] @relation("UserFavorites")
  reviews       Review[]
  orders        Order[]
  orderItems    OrderItem[]
  products      Product[] @relation("UserProducts")
  brand         Brand[]
  category      Category[]
  billingInfo   BillingInfo?
  subscription  Subscription[]

  stripeAccountId String? @map("stripe_account_id")

  sellerTransfers   TransferLog[] @relation("SellerTransferLogs")

  role  EnumRole   @default(USER)
  @@map("user")
  // TODO - add indexes for all schemas
  @@index([id])
  @@index([email])

}

model Store {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  title       String
  description String?
  images      String[]
  country    String?
  city       String?
  address    String?
  phone      String?

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @map("user_id")

  products   Product[]
  categories Category[]
  colors     Color[]
  reviews    Review[]
  orderItems OrderItem[]
  brands     Brand[]


  isDefaultStore Boolean @default(false)
  isPublished    Boolean @default(true)
  isBlocked      Boolean @default(false)

  @@map("store")

  @@index([id])
  @@index([title])
  @@index([description])
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  title       String
  description String?
  price       Float
  oldPrice    Float?
  images      String[]

  state EnumProductState @default(NEW)

  reviews    Review[]
  orderItems OrderItem[]
  productDetails ProductDetail[]

  totalViews Int @default(0)
  totalLikes Int @default(0)

  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId String? @map("store_id")

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?   @map("category_id")

  color   Color? @relation(fields: [colorId], references: [id], onDelete: SetNull)
  colorId String? @map("color_id")

  user User?   @relation("UserProducts", fields: [userId], references: [id], onDelete: Cascade)
  userId    String? @map("user_id")

  favoritedBy User[] @relation("UserFavorites")

  brand   Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  brandId String? @map("brand_id")

  isPublished Boolean @default(true)
  isBlocked   Boolean @default(false)
  isOriginal   Boolean @default(true)
  quantity    Int     @default(1)

  @@map("product")

  @@index([id])
  @@index([title])
  @@index([description])
  @@index([isPublished])
}

model ProductDetail {
  id    String @id @default(cuid())

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  key   String
  value String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")

  @@unique([productId, key])
  @@index([value])
  @@map("product_detail")
}

model Category {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name        String @unique
  description String?
  images      String[]
  rating      Float?
  products Product[]

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  user   User?  @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  @@map("category")

  @@index([id])
  @@index([name])
  @@index([description])
}

model Brand {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name String @unique
  description String?
  images      String[]
  rating      Float?

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  user   User?  @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  products Product[]

  @@map("brand")

  @@index([id])
  @@index([name])
  @@index([description])
}

model Color {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name  String @unique
  value String

  products Product[]

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  @@map("color")

  @@index([id])
  @@index([name])
}

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  text   String
  rating Int

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @map("user_id")

  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String?  @map("product_id")

  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId String? @map("store_id")

  @@map("review")

  @@index([id])
  @@index([text])
}

model Plan {
  id       String               @id @default(cuid())

  planId   EnumSubscriptionType @unique @map("plan_id")
  description String

  price             Float
  period            BillingPeriod
  storeLimit        Int?           @map("store_limit")
  productLimit      Int?           @map("product_limit")
  isPopular Boolean @default(false) @map("is_popular")

  stripeProductId String               @map("stripe_product_id")
  stripePriceId String?              @map("stripe_price_id")

  features String[]

  subscriptions     Subscription[]
  nextSubscriptions Subscription[] @relation("NextPlan")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plan")

  @@index([id])
  @@index([planId])
}

model Subscription {
  id        String   @id @default(cuid())

  stripeSubscriptionId String? @map("stripe_subscription_id")

  status EnumSubscriptionStatus @default(PENDING)
  startDate DateTime @default(now()) @map("start_date")
  endDate   DateTime? @map("end_date")
  nextBillingDate DateTime?              @map("next_billing_date")
  trialEndAt      DateTime?              @map("trial_end_at")
  period       BillingPeriod
  storeLimit   Int?         @map("store_limit")
  productLimit Int?         @map("product_limit")
  customerId   String?      @map("customer_id")

  order     Order?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  plan   Plan                 @relation(fields: [planId], references: [planId])
  planId EnumSubscriptionType @map("plan_id")

  nextPlan   Plan?                 @relation("NextPlan", fields: [nextPlanId], references: [planId])
  nextPlanId EnumSubscriptionType? @map("next_plan_id")

  cancelledAt     DateTime? @map("cancelled_at")
  cancelledReason Json?     @map("cancelled_reason")
  pausedAt        DateTime? @map("paused_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription")

  @@index([id])
  @@index([status])
}

model Order {
  id        String   @id @default(cuid())

  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  stripeSessionId String? @map("stripe_session_id")
  stripeChargeId String? @map("stripe_charge_id")
  totalPrice      Float

  provider    PaymentProvider
  status      EnumOrderStatus @default(PENDING)

  externalId  String? @map("external_id")
  providerMeta Json?  @map("provider_meta")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  subscriptionId  String? @unique @map("subscription_id")
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  transferLogs      TransferLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("order")

  @@index([id])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quantity Int
  price    Float

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String? @map("order_id")

  product   Product? @relation(fields: [productId], references: [id])
  productId String?  @map("product_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  cachedProductTitle String?
  cachedProductImages String[]
  status      EnumOrderItemStatus @default(PENDING)

  stripeTransferId String? @map("stripe_transfer_id")
  transferCompletedAt DateTime @default(now()) @map("transfer_completed_at")

  store   Store?  @relation(fields: [storeId], references: [id])
  storeId String? @map("store_id")

  transferLogs      TransferLog[]

  @@map("order_item")

  @@index([id])
  @@index([status])
}

model BillingInfo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique @map("user_id")

  serviceId String @map("service_id")

  stripeCustomerId           String? @map("stripe_customer_id")
  stripeDefaultPaymentMethod String? @map("stripe_default_payment_method")

  stripeTestClockId String? @map("stripe_test_clock_id")
  @@map("billing_info")
}

model TransferLog {
  id                String   @id @default(cuid())
  // Relations
  orderId           String   @map("order_id")
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderItemId       String    @map("order_item_id")
  orderItem         OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  sellerId          String   @map("seller_id")
  seller            User     @relation("SellerTransferLogs", fields: [sellerId], references: [id], onDelete: Cascade)

  // Stripe IDs
  stripeTransferId  String?   @map("stripe_transfer_id") @unique // уникальный трансфер ID
  stripeReversalId  String?   @map("stripe_reversal_id") // ID реверса (при refund)
  stripeRefundId    String?   @map("stripe_refund_id")// ID рефунда покупателю

  // Суммы (в cents)
  grossAmount       Int      @map("gross_amount")// полная сумма (что платил покупатель)
  transferAmount    Int      @map("transfer_amount")// сумма для продавца (95%)
  commission        Int      @map("commission")// комиссия платформы (5%)

  // Статус
  status            String   // 'SUCCEEDED', 'FAILED', 'REVERSED', 'REFUNDED'
  errorMessage      String?  @map("error_message")// если FAILED

  // Дополнительно
  reason            String?  // причина возврата (если refund)
  metadata          Json?    // дополнительные данные

  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Индексы для быстрого поиска
  @@index([orderId])
  @@index([orderItemId])
  @@index([sellerId])
  @@index([stripeTransferId])
  @@index([status])
  @@index([createdAt])
}

enum EnumProductState {
  NEW
  USED
}

enum BillingPeriod {
  MONTHLY
  YEARLY

  @@map("billing_period")
}

enum EnumSubscriptionType {
  FREE
  ADVANCED
  ADVANCED_ANNUAL
  PREMIUM
  PREMIUM_ANNUAL
}

enum EnumSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  PENDING_DOWNGRADE
  UPGRADING
  OVERDUE
  PAUSED
  TRIALING

  @@map("subscription_status")
}

enum PaymentProvider {
  STRIPE
  YOOKASSA

  @@map("payment_provider")
}

enum EnumOrderStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
  PAUSED
  CONFIRMED

  @@map("order_status")
}

enum EnumOrderItemStatus {
  PENDING
  FAILED
  REFUNDED
  CONFIRMED
  EXPIRED

  @@map("order_item_status")
}

enum CurrencyEnum {
  USD
  EUR
  RUB
  @@map("currency_enum")
}

enum EnumRole {
  USER
  ADMIN
  SUPER_ADMIN
}